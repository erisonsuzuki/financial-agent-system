# PostgreSQL DB Connection
POSTGRES_DB=financialdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# LLM Configuration
LLM_PROVIDER="groq" # Can be "groq" or "nvidia"
LLM_FALLBACK_PROVIDER="nvidia"

# For Groq
GROQ_MODEL="openai/gpt-oss-20b"
GROQ_API_KEY="your_groq_key"

# For Nemotron
NVIDIA_MODEL="nvidia/nemotron-3-nano-30b-a3b"
NVIDIA_API_KEY="your_nvidia_key"

# JWT configuration
JWT_SECRET_KEY=change-me-in-prod
JWT_EXPIRE_MINUTES=60

# FastAPI base URL (used by the Next.js UI when running outside Docker)
FASTAPI_BASE_URL=http://localhost:8000

# Internal API URL for agents (only if running outside Docker)
INTERNAL_API_URL=http://localhost:8000

# Application DB URL (used only when running outside Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/financialdb
